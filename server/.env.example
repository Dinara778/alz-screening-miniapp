# Токен бота @BotFather
TELEGRAM_BOT_TOKEN=

# Токен провайдера оплат: BotFather → ваш бот → Payments → подключить ЮKassa / Stripe и т.д.
# Для Telegram Stars используется другой сценарий (валюта XTR) — см. документацию Telegram.
TELEGRAM_PAYMENT_PROVIDER_TOKEN=

# Порт локального сервера
PORT=8787

# --- Заявка «Запись на разбор» (POST /consultation-lead) ---
# Куда слать письмо (по умолчанию на сервере уже hello@bookvolon.ru, можно переопределить)
CONSULTATION_LEAD_TO=hello@bookvolon.ru

# SMTP для отправки писем (например Яндекс 360 / корпоративная почта). Без этого письмо не уйдёт.
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
# Адрес отправителя (часто совпадает с SMTP_USER или ящик домена)
SMTP_FROM=

# Резерв без почты: ID чата (или пользователя), куда бот пришлёт текст заявки. Узнать: @userinfobot / getUpdates
TELEGRAM_ADMIN_CHAT_ID=
