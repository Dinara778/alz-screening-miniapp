# Токен бота @BotFather
TELEGRAM_BOT_TOKEN=

# HTTPS URL мини-приложения (тот же, что в @BotFather → Bot Settings → Mini App).
# Нужен для ответа на /start: сообщение с кнопкой «Открыть приложение».
TELEGRAM_MINI_APP_URL=https://your-amvera-or-pages-domain.example.com

# Ссылка на Mini App в Telegram (из @BotFather → Mini App → Test / t.me/…)
# TELEGRAM_MINI_APP_TME_LINK=https://t.me/YourBot/corta

# Или только username бота (если нет short link): https://t.me/YourBot
# TELEGRAM_BOT_USERNAME=YourBot

# URL вебхука (если не задан — берётся PAYMENTS_PUBLIC_BASE_URL + /webhook). При старте сервера вызывается setWebhook.
# TELEGRAM_WEBHOOK_URL=https://your-api.example.com/webhook

# Один домен для фронта и API (Dockerfile.unified + SERVE_STATIC=true):
# SERVE_STATIC=true

# Необязательно: переопределить тексты /start (по умолчанию — системный шрифт Telegram + bold через entities)
# TELEGRAM_START_MESSAGE=
# TELEGRAM_START_PHOTO_CAPTION=  # свой текст; для жирного: <b>заголовок</b> (HTML)
# TELEGRAM_START_BUTTON_TEXT=Открыть приложение
# Фото: логотип corta-logo.png (public/ → dist/ при сборке)
# TELEGRAM_START_PHOTO_URL=https://your-domain.example.com/corta-logo.png
# TELEGRAM_START_PHOTO_CAPTION=
# TELEGRAM_START_PHOTO_DISABLED=true

# Для нативной оплаты Telegram (по умолчанию): BotFather → Payments → провайдер (ЮKassa и т.д.)
TELEGRAM_PAYMENT_PROVIDER_TOKEN=

# Чеки 54-ФЗ через ЮKassa (обязательно при «Чеки от ЮKassa» — иначе «Заплатить не получилось»)
# Коды из личного кабинета ЮKassa / настроек онлайн-кассы (см. документацию провайдера)
# YOOKASSA_RECEIPT_TAX_SYSTEM_CODE=1
# YOOKASSA_RECEIPT_VAT_CODE=1
# service — услуга (отчёт, сессия); commodity — товар
# YOOKASSA_RECEIPT_PAYMENT_SUBJECT=service
# YOOKASSA_RECEIPT_PAYMENT_MODE=full_payment

# --- Оплата ---
# none — оплата выключена (Prodamus/Telegram; сессия — заявка POST /consultation-lead)
# prodamus — ссылка на payform.ru (внешняя страница)
# telegram — счёт внутри Telegram (нужен TELEGRAM_PAYMENT_PROVIDER_TOKEN, BotFather → Payments)
# auto — telegram при токене, иначе prodamus при полном наборе PRODAMUS_*, иначе none
PAYMENT_PROVIDER=none
# PAYMENT_PROVIDER=prodamus
# URL платёжной страницы из браузера (https://ваш-поддомен.payform.ru/)
# PRODAMUS_FORM_URL=
# Секретный ключ со страницы настроек формы
# PRODAMUS_SECRET_KEY=
# Код интеграции sys (согласуйте с поддержкой Prodamus; для самописных иногда оставляют пустым)
# PRODAMUS_SYS=
# Публичный HTTPS-адрес ЭТОГО сервера (как VITE_TELEGRAM_PAYMENTS_URL у фронта), без слэша в конце — для вебхука /prodamus/notify
# PAYMENTS_PUBLIC_BASE_URL=https://your-api.example.com

PORT=8787

# --- Заявка «Запись на разбор» (POST /consultation-lead) ---
# Куда слать письмо (по умолчанию на сервере уже hello@bookvolon.ru, можно переопределить)
CONSULTATION_LEAD_TO=hello@bookvolon.ru

# SMTP для отправки писем (например Яндекс 360 / корпоративная почта). Без этого письмо не уйдёт.
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
# Адрес отправителя (часто совпадает с SMTP_USER или ящик домена)
SMTP_FROM=

# Резерв без почты: ID чата (или пользователя), куда бот пришлёт текст заявки. Узнать: @userinfobot / getUpdates
TELEGRAM_ADMIN_CHAT_ID=

# Аналитика Google Таблица (опционально при запуске; иначе URL из VITE_SHEETS_WEBHOOK_URL в build-info.json)
# SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/ВАШ_ID/exec
