VITE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_WEB_APP_ID/exec
# Ссылка на бота/мини-приложение для кнопки «Поделиться»
VITE_SHARE_BOT_URL=https://t.me/cortalab_ns_bot
# HTTPS URL сервера оплат (папка server/) — без слеша в конце. Без URL оплата недоступна.
# Тот же хост, что PAYMENTS_PUBLIC_BASE_URL на сервере (для Prodamus — нужен POST /prodamus/notify).
VITE_TELEGRAM_PAYMENTS_URL=https://your-domain.example.com
# Оплата на фронте: false — отчёт и сессия без Payform/Prodamus (заявка на сессию по почте). Включить после ЮKassa: true
# VITE_PAYMENTS_ENABLED=false
# Только для разработки без Prodamus: сразу открывает отчёт/сессию без оплаты. На проде не задавать.
# VITE_DEV_BYPASS_REPORT_PAYMENT=true
