# Google Sheets: URL веб-приложения Apps Script. Задаётся при СБОРКЕ на Amvera.
# Пошагово: docs/analytics-setup.md
# VITE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/ВАШ_ID/exec
# Ссылка на бота/мини-приложение для кнопки «Поделиться»
VITE_SHARE_BOT_URL=https://t.me/cortalab_ns_bot
# HTTPS URL сервера оплат (папка server/) — без слеша в конце. Без URL оплата недоступна.
# Тот же хост, что PAYMENTS_PUBLIC_BASE_URL на сервере (для Prodamus — нужен POST /prodamus/notify).
VITE_TELEGRAM_PAYMENTS_URL=https://your-domain.example.com
# Оплата на фронте: false (по умолчанию в Dockerfile) — расширенный отчёт открывается сразу, сессия по заявке.
# На проде: true или не задавать (если сервер /health → payments.ready с ЮKassa)
# VITE_PAYMENTS_ENABLED=true
# Только локально: отчёт без оплаты
# VITE_DEV_BYPASS_REPORT_PAYMENT=true
# Личный кабинет /cabinet (Supabase Auth magic link) — при сборке на Amvera
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...   # anon public, не service_role
